--- a/ggml/src/ggml-vulkan/CMakeLists.txt
+++ b/ggml/src/ggml-vulkan/CMakeLists.txt
@@ -6,7 +6,14 @@ if (POLICY CMP0147)
     cmake_policy(SET CMP0147 NEW)
 endif()
 
-find_package(Vulkan COMPONENTS glslc REQUIRED)
+if (ANDROID)
+    # Android: Vulkan is available via NDK (libvulkan.so), no glslc needed
+    # Shaders are compiled at runtime by the Vulkan driver
+    find_package(Vulkan REQUIRED)
+    set(Vulkan_GLSLC_EXECUTABLE "")
+else()
+    find_package(Vulkan COMPONENTS glslc REQUIRED)
+endif()
 
 if (DEFINED ENV{VULKAN_SDK})
     list(APPEND CMAKE_PREFIX_PATH "$ENV{VULKAN_SDK}")
@@ -56,6 +63,7 @@ if (CMAKE_CXX_COMPILER_ID STREQUAL "MSVC")
     add_compile_definitions(/MP)
 endif()
 
+if (NOT ANDROID)
 # Function to test shader extension support
 # Parameters:
 #  EXTENSION_NAME - Name of the extension to test (e.g., "GL_EXT_integer_dot_product")
@@ -92,6 +100,7 @@ if (Vulkan_FOUND)
         GGML_VULKAN_BFLOAT16_GLSLC_SUPPORT
     )
 
+
     if (GGML_VULKAN_SHADER_DEBUG_INFO)
         add_compile_definitions(GGML_VULKAN_SHADER_DEBUG_INFO)
         list(APPEND VULKAN_SHADER_GEN_CMAKE_ARGS -DGGML_VULKAN_SHADER_DEBUG_INFO=ON)
@@ -150,6 +159,10 @@ if (Vulkan_FOUND)
         set(HOST_CMAKE_TOOLCHAIN_FILE "")
     endif()
 
+
+    # Skip shader pre-compilation on Android (runtime shader compilation)
+
+if (NOT CMAKE_CROSSCOMPILING)
     include(ExternalProject)
     if (CMAKE_CROSSCOMPILING)
         list(APPEND VULKAN_SHADER_GEN_CMAKE_ARGS -DCMAKE_TOOLCHAIN_FILE=${HOST_CMAKE_TOOLCHAIN_FILE})
@@ -225,6 +238,16 @@ if (Vulkan_FOUND)
                     vulkan-shaders-gen
             COMMENT "Generate vulkan shaders for ${file}"
         )
+        target_sources(ggml-vulkan PRIVATE ${_ggml_vk_target_cpp})
+    endforeach()
+    # Re-add the header source
+    target_sources(ggml-vulkan PRIVATE ${_ggml_vk_header})
+    # Add dependency on the external project
+    add_dependencies(ggml-vulkan vulkan-shaders-gen)
+else()
+    # Cross-compiling or Android: skip ExternalProject shader gen
+    # Runtime shader compilation will be used
+    message(STATUS "Vulkan shader pre-compilation skipped (cross-compile/Android)")
     endif()
 
 else()
