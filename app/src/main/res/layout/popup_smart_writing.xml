<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="@drawable/popup_bg">

    <!-- 标题 -->
    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center"
        android:padding="10dp"
        android:text="✨ 智能写作设置"
        android:textSize="18sp"
        android:textColor="#81D8D0"
        android:textStyle="bold"
        android:background="#1A1A2E" />

    <!-- 三个来源选项（单栏） -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="8dp">

        <TextView
            android:id="@+id/opt_clipboard"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:padding="10dp"
            android:text="○ 📋 剪贴板首条"
            android:textSize="14sp"
            android:textColor="#333333"
            android:background="?attr/selectableItemBackground"
            android:tag="clipboard" />

        <TextView
            android:id="@+id/opt_grammar"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:padding="10dp"
            android:text="○ 📖 语法大纲"
            android:textSize="14sp"
            android:textColor="#333333"
            android:background="?attr/selectableItemBackground"
            android:tag="grammar" />

        <TextView
            android:id="@+id/opt_search"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:padding="10dp"
            android:text="○ 🌐 互联网搜索"
            android:textSize="14sp"
            android:textColor="#333333"
            android:background="?attr/selectableItemBackground"
            android:tag="search" />
    </LinearLayout>

    <!-- 分隔线 -->
    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="#CCCCCC"
        android:layout_marginHorizontal="12dp" />

    <!-- 魔法记录区标题 -->
    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="8dp"
        android:paddingStart="12dp"
        android:text="📝 魔法记录"
        android:textSize="13sp"
        android:textColor="#81D8D0"
        android:textStyle="bold" />

    <!-- 魔法记录列表 -->
    <ListView
        android:id="@+id/lv_magic_records"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:divider="#EEEEEE"
        android:dividerHeight="1dp"
        android:paddingHorizontal="8dp"
        android:scrollbars="vertical"
        android:listSelector="@android:color/transparent" />

    <!-- 手动输入区 -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:padding="8dp"
        android:gravity="center_vertical">

        <EditText
            android:id="@+id/et_magic_input"
            android:layout_width="0dp"
            android:layout_height="36dp"
            android:layout_weight="1"
            android:hint="输入智能写作指令..."
            android:textSize="13sp"
            android:paddingHorizontal="8dp"
            android:background="#F5F5F5"
            android:inputType="text"
            android:imeOptions="actionDone"
            android:maxLines="1" />

        <TextView
            android:id="@+id/btn_add_record"
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:layout_marginStart="4dp"
            android:gravity="center"
            android:text="＋"
            android:textSize="18sp"
            android:textColor="#81D8D0"
            android:background="?attr/selectableItemBackground"
            android:contentDescription="添加指令" />
    </LinearLayout>

    <!-- 底部按钮栏 -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="44dp"
        android:orientation="horizontal"
        android:gravity="center"
        android:background="#F5F5F5"
        android:elevation="2dp">

        <TextView
            android:id="@+id/btn_confirm"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:gravity="center"
            android:text="✅ 确认"
            android:textSize="15sp"
            android:textColor="#81D8D0"
            android:textStyle="bold"
            android:background="?attr/selectableItemBackground"
            android:contentDescription="确认" />

        <View
            android:layout_width="1dp"
            android:layout_height="20dp"
            android:layout_gravity="center_vertical"
            android:background="#DDDDDD" />

        <TextView
            android:id="@+id/btn_close_smart"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:gravity="center"
            android:text="⨯ 关闭"
            android:textSize="15sp"
            android:textColor="#81D8D0"
            android:background="?attr/selectableItemBackground"
            android:contentDescription="关闭" />
    </LinearLayout>

</LinearLayout>
