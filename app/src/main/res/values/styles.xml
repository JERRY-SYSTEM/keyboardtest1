<?xml version="1.0" encoding="utf-8"?>
<resources>
    <!-- 明亮主题 -->
    <style name="Theme.Cesia" parent="Theme.MaterialComponents.Light.NoActionBar">
        <item name="android:windowBackground">@color/bg_primary</item>
        <item name="colorPrimary">@color/accent</item>
        <item name="colorPrimaryDark">@color/accent</item>
        <item name="colorAccent">@color/accent</item>
    </style>

    <!-- 黑暗主题 -->
    <style name="Theme.Cesia.Dark" parent="Theme.MaterialComponents.NoActionBar">
        <item name="android:windowBackground">#1A1A2E</item>
        <item name="colorPrimary">#FF03DAC5</item>
        <item name="colorPrimaryDark">#FF03DAC5</item>
        <item name="colorAccent">#FF03DAC5</item>
        <item name="android:textColorPrimary">#E0E0E0</item>
        <item name="android:textColorSecondary">#AAAAAA</item>
        <item name="android:colorBackground">#1A1A2E</item>
    </style>
</resources>
