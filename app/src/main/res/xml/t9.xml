<?xml version="1.0" encoding="utf-8"?>
<!--
    T9 键盘布局 — 仿传统手机 12 键
    - 短按数字键(2-9)：触发 T9 拼音输入（abc/def/ghi/jkl/mno/pqrs/tuv/wxyz）
    - 长按数字键：直接输入数字
    - 1：符号，0：空格，*：退格，#：回车
-->
<Keyboard xmlns:android="http://schemas.android.com/apk/res/android"
    android:keyWidth="33%p"
    android:keyHeight="56dp"
    android:horizontalGap="2dp"
    android:verticalGap="4dp">

    <!-- 第1行：1(符号)  2(abc)  3(def) -->
    <Row>
        <Key android:codes="49" android:keyLabel="1" android:keyEdgeFlags="left" />
        <Key android:codes="50" android:keyLabel="2\nabc" />
        <Key android:codes="51" android:keyLabel="3\ndef" android:keyEdgeFlags="right" />
    </Row>

    <!-- 第2行：4(ghi)  5(jkl)  6(mno) -->
    <Row>
        <Key android:codes="52" android:keyLabel="4\nghi" android:keyEdgeFlags="left" />
        <Key android:codes="53" android:keyLabel="5\njkl" />
        <Key android:codes="54" android:keyLabel="6\nmno" android:keyEdgeFlags="right" />
    </Row>

    <!-- 第3行：7(pqrs)  8(tuv)  9(wxyz) -->
    <Row>
        <Key android:codes="55" android:keyLabel="7\npqrs" android:keyEdgeFlags="left" />
        <Key android:codes="56" android:keyLabel="8\ntuv" />
        <Key android:codes="57" android:keyLabel="9\nwxyz" android:keyEdgeFlags="right" />
    </Row>

    <!-- 第4行：*(退格)  0(空格/符号)  #(回车) -->
    <Row>
        <Key android:codes="-5" android:keyLabel="*" android:isRepeatable="true"
            android:keyEdgeFlags="left" />
        <Key android:codes="48" android:keyLabel="0\n " />
        <Key android:codes="10" android:keyLabel="#" android:keyEdgeFlags="right" />
    </Row>

</Keyboard>
